// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}


model Categorie {
  id Int @id @default(autoincrement())
  name String
  coleur String
  produits Produit[]
  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
}

model Produit {
  id Int @id @default(autoincrement())
  name String
  description String
  price Float
  IdCategorie Int 
  ventes Vente[]
  categorie Categorie @relation(fields: [IdCategorie], references: [id])
  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
}

model Vendeur {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  clients Client[]
  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
}

model Client {
  id Int @id @default(autoincrement())
  name String
  prenom String
  idVendeur Int
  ventes Vente[]
  vendeur Vendeur @relation(fields: [idVendeur], references: [id])
  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
}

model Vente {
  id Int @id @default(autoincrement())
  idProduit Int
  idClient Int
  Qte Int
  CordonnéGPS String
  produit Produit @relation(fields: [idProduit], references: [id])
  client Client @relation(fields: [idClient], references: [id])
  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
  }



